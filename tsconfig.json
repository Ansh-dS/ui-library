{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    // "rootDir": "./src",
    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext",
    "target": "esnext",
    "types": [],
    "composite": true,
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node
    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,
    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    // path allies
    "baseUrl": ".",
    "paths": {
      /*
      if we want to use file of one subfolder in other,
      then we must inculde it in vite.config as well as here. 

      if the files are at root then it's "ok" to define it in vite.config.ts.
      */
      "@components": ["./packages/ui/src/index.ts"]
    }
  },
  "include": ["packages/**/*", "*.ts", "apps/**/*"],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/tests",
    "**/storybook-static"
  ]
}
