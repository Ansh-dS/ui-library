{
  "tasks": {
    "lint": {
      "cache": true
    },
    "build": {
      "outputs": ["dist/**", ".next/**"],
      "cache": false,
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": false
    }
  }
}
